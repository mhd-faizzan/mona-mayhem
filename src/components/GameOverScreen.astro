---
// *bleep* *bloop* pending game over display
export interface StatItem {
  label: string;
  value: string | number;
}

export interface Props {
  winner: string;
  status: 'VICTORY' | 'DEFEAT' | 'DRAW';
  stats: StatItem[];
  playAgainId?: string;
  subtitle?: string;
}

const {
  winner,
  status,
  stats,
  playAgainId = 'play-again',
  subtitle = 'THE ARENA REMEMBERS YOUR LAST BATTLE',
} = Astro.props;
---

<div class="game-over-screen">
  <div class="game-over-card">
    <div class="card-header">
      <span class="label">GAME OVER</span>
      <h1>{status}</h1>
    </div>

    <div class="winner-panel">
      <p class="winner-caption">WINNER</p>
      <p class="winner-name">{winner}</p>
      <p class="winner-subtitle">{subtitle}</p>
    </div>

    <div class="stat-grid">
      {stats.map((stat) => (
        <div class="stat-item">
          <span class="stat-name">{stat.label}</span>
          <span class="stat-value">{stat.value}</span>
        </div>
      ))}
    </div>

    <button id={playAgainId} class="play-again-button" type="button">
      PLAY AGAIN
    </button>
  </div>
</div>

<style>
.game-over-screen {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 2rem;
  background: radial-gradient(circle at top, rgba(0, 255, 65, 0.08), transparent 28%),
    radial-gradient(circle at right, rgba(255, 0, 255, 0.08), transparent 22%),
    #0a0a0f;
  color: #e0e0ff;
  font-family: 'Courier New', Courier, monospace;
}

.game-over-card {
  width: min(760px, 100%);
  display: grid;
  gap: 1.5rem;
  padding: 2rem;
  border: 2px solid #1a1a3e;
  border-radius: 1.5rem;
  background: rgba(13, 13, 26, 0.95);
  box-shadow: 0 0 3rem rgba(255, 0, 255, 0.18), 0 0 2rem rgba(0, 255, 65, 0.12);
  backdrop-filter: blur(12px);
}

.card-header {
  display: grid;
  gap: 0.25rem;
  text-align: center;
}

.label {
  color: #00ffff;
  letter-spacing: 0.3em;
  font-size: 0.8rem;
  text-transform: uppercase;
}

h1 {
  margin: 0;
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(2rem, 4vw, 3.25rem);
  letter-spacing: 0.25em;
  text-transform: uppercase;
}

.winner-panel {
  display: grid;
  gap: 0.5rem;
  padding: 1.5rem;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: linear-gradient(180deg, rgba(10, 10, 15, 0.9), rgba(20, 20, 40, 0.95));
  border-radius: 1rem;
}

.winner-caption {
  margin: 0;
  color: #7df5ff;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  font-size: 0.8rem;
}

.winner-name {
  margin: 0;
  font-size: 2rem;
  color: #00ff41;
  letter-spacing: 0.16em;
}

.winner-subtitle {
  margin: 0;
  color: #c0c0ff;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.stat-item {
  padding: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 1rem;
  background: rgba(10, 10, 20, 0.8);
  box-shadow: inset 0 0 0.75rem rgba(255, 0, 255, 0.04);
}

.stat-name {
  display: block;
  color: #7df5ff;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 0.5rem;
}

.stat-value {
  display: block;
  font-size: 1.25rem;
  color: #e0e0ff;
}

.play-again-button {
  justify-self: center;
  padding: 1rem 2rem;
  border: 2px solid #ff00ff;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(255, 0, 255, 0.22), rgba(0, 255, 255, 0.12));
  color: #f9f9ff;
  font-family: 'Press Start 2P', monospace;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  cursor: pointer;
  box-shadow: 0 0 2rem rgba(255, 0, 255, 0.25), 0 0 2rem rgba(0, 255, 255, 0.12);
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}

.play-again-button:hover {
  transform: translateY(-3px);
  background: linear-gradient(135deg, rgba(255, 0, 255, 0.35), rgba(0, 255, 255, 0.18));
}

@media (max-width: 640px) {
  .stat-grid {
    grid-template-columns: 1fr;
  }
}
</style>
